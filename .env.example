# Copy this file to ".env" and fill in your keys. NEVER commit the real .env file.

# Your Anthropic API key — get it at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxx

# Your Voyage AI key (for embeddings) — get it at https://dash.voyageai.com
# Voyage makes the embedding models Anthropic recommends for use with Claude.
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxxxxxxxxxx

# Claude model to use (see https://docs.claude.com for current model strings)
CLAUDE_MODEL=claude-sonnet-5

# Embedding model. voyage-3.5 is multilingual — important for non-English customers.
EMBED_MODEL=voyage-3.5

# Server port
PORT=3000

# Comma-separated list of sites allowed to call the bot (CORS).
# Use your real domain in production, e.g. https://esportsbet.io
ALLOWED_ORIGINS=*

# Minimum retrieval confidence (0-1). Below this, the bot won't guess — it
# defers to a human. Tune after testing with real questions.
MIN_CONFIDENCE=0.45
